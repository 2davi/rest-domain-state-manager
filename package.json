{
  "name": "@2davi/rest-domain-state-manager",
  "version": "0.5.0",
  "description": "Proxy-based REST Domain State Manager for smart change tracking and auto-branching HTTP methods.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --emitDeclarationOnly",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.{js,ts,html,css}\"",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "rest",
    "proxy",
    "state-management",
    "json-patch",
    "esm"
  ],
  "author": "2davi",
  "license": "ISC",
  "devDependencies": {
    "eslint": "^9.0.0",
    "prettier": "^3.5.0",
    "terser": "^5.46.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
