{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["index.js", "./src/**/*.js"],
  "entryPointStrategy": "expand",
  "out": "docs/api",
  "plugin": ["typedoc-plugin-markdown"],
  "hideBreadcrumbs": true,
  "hidePageHeader": true,
  "readme": "none",
  "disableSources": true,
  "flattenOutputFiles": true
}