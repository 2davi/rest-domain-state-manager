{
    "compilerOptions": {
        "target":              "ESNext",
        "module":              "ESNext",
        "lib":                 ["ESNext", "DOM"],

        "allowJs":             true,
        "checkJs":             false,

        "declaration":         true,
        "declarationDir":      "./dist",
        "declarationMap":      true,
        "emitDeclarationOnly": true,

        "moduleResolution":    "bundler",
        "strict":              true,
        "skipLibCheck":        true
    },
    "include": ["src/**/*", "index.js"]
}