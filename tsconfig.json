{
    "compilerOptions": {
        "target":           "ESNext",
        "module":           "ESNext",
        "lib":              ["ESNext", "DOM"],

        "allowJs":          true,
        "checkJs":          true,

        "noEmit":           true,

        "moduleResolution": "bundler",
        "strict":           true,
        "skipLibCheck":     true
    },
    "include": ["src/**/*", "index.js"]
}